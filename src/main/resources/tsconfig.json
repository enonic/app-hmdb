{
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "**/*.d.ts",
    "assets/**/*.*"
  ],
  "compilerOptions": {
    "paths": {
      "/lib/xp/*": ["../../../node_modules/@enonic-types/lib-*"],
      "/lib/enonic/asset": ["../../../node_modules/@enonic-types/lib-asset"],
      "/lib/*": ["../../../node_modules/@item-enonic-types/lib-*"],
      "/*": ["./*"]
    },
    "skipLibCheck": true,
    "types": [
      "@enonic-types/global"
    ]
  }
}
