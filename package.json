{
  "devDependencies": {
    "@enonic-types/core": "^8.0.3",
    "@enonic-types/global": "^8.0.3",
    "@enonic-types/lib-asset": "^2.0.1",
    "@enonic-types/lib-cluster": "^8.0.3",
    "@enonic-types/lib-content": "^8.0.2",
    "@enonic-types/lib-context": "^8.0.3",
    "@enonic-types/lib-export": "^8.0.3",
    "@enonic-types/lib-portal": "^8.0.2",
    "@enonic-types/lib-project": "^8.0.3",
    "@enonic-types/lib-task": "^8.0.3",
    "@eslint/js": "^10.0.1",
    "@item-enonic-types/lib-thymeleaf": "^2.1.0",
    "@swc/core": "^1",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "glob": "^13.0.6",
    "tsdown": "^0.22.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  },
  "private": true,
  "scripts": {
    "build": "tsdown",
    "check": "concurrently -c auto -g --timings npm:check:types npm:lint",
